---
import { Code } from "astro:components";
import Layout from "../layouts/Layout.astro";
import HeroAura from "../components/HeroAura";
import GlowDemo from "../components/GlowDemo";
import AuraDemo from "../components/AuraDemo";
import LockDemo, { KEYWORD as LOCK_KEYWORD } from "../components/LockDemo";

const installCmd = "npm i @p4ni/ui";
const localeCopy = {
  en: {
    meta: {
      title: "@p4ni/ui — inputs that glow",
      description:
        "WebGL & CSS effect components for React. Real DOM inputs, shader-grade light. IME, paste and a11y stay intact.",
    },
    language: {
      label: "language",
      switcher: "language switcher",
    },
    nav: {
      components: "components",
      github: "github",
      npm: "npm",
    },
    hero: {
      eyebrow: "react ui effects · glow components",
      title: "Inputs that <em>glow</em>.",
      lede:
        "WebGL &amp; CSS effect components for React. <strong>The &lt;input&gt; stays real DOM</strong> — IME, paste and accessibility intact. The light is just light.",
    },
    common: {
      copy: "copy",
      copied: "copied",
    },
    glow: {
      description:
        "A glowing input built from a rotating conic-gradient edge and drop shadows. Zero dependencies, lightweight, and copy-paste friendly.",
    },
    aura: {
      description:
        "The WebGL upgrade for GlowInput. Rounded-box SDF and value-noise shader fog drift around the input edge and pulse while you type. The canvas uses <code>pointer-events: none</code>, so the input remains real DOM.",
      note:
        "peer deps: <code>npm i three @react-three/fiber</code> — Next.js should load it with <code>dynamic(…, &#123; ssr: false &#125;)</code>.",
    },
    lock: {
      description:
        "A 3D padlock with a real <code>&lt;input&gt;</code> embedded in its face. Enter the correct keyword and the shackle springs open while the lock dissolves into particles, revealing your content. A wrong answer shakes it and flares it coral.",
      note:
        "peer deps: <code>npm i three @react-three/fiber</code> — theatrical, not cryptographic: the keyword ships in the client bundle, so authorize real secrets on the server.",
    },
    skyline: {
      tags: "coming soon",
      title: "in orbit —",
      description:
        "A React port of astro-skyline. City lights sit on the horizon of your form.",
    },
    principles: {
      domTitle: "Real DOM first",
      domBody:
        "All decoration lives in background layers. The input itself stays untouched, so Japanese IME, paste, and screen readers keep working.",
      ssrTitle: "SSR safe",
      ssrBody:
        "The canvas is created only after mount. In Next.js, use a <code>ssr: false</code> dynamic import.",
      motionTitle: "Respects motion prefs",
      motionBody:
        "With <code>prefers-reduced-motion</code>, animation slows to near stillness. Off-screen rendering is paused with IntersectionObserver.",
    },
  },
  ja: {
    meta: {
      title: "@p4ni/ui — 光る input コンポーネント",
      description:
        "React 向けの WebGL / CSS エフェクトコンポーネント。input は本物の DOM のままで、IME・ペースト・アクセシビリティを保ちます。",
    },
    language: {
      label: "言語",
      switcher: "言語切替",
    },
    nav: {
      components: "コンポーネント",
      github: "github",
      npm: "npm",
    },
    hero: {
      eyebrow: "react ui effects · 発光コンポーネント",
      title: "Inputs that <em>glow</em>.",
      lede:
        "React 向けの WebGL / CSS エフェクトコンポーネント。<strong>&lt;input&gt; は本物の DOM のまま</strong> なので、IME・ペースト・アクセシビリティを保てます。光だけを重ねます。",
    },
    common: {
      copy: "コピー",
      copied: "コピー済み",
    },
    glow: {
      description:
        "回転する conic-gradient の縁とドロップシャドウで作る発光 input。依存ゼロで軽量、コピペでもそのまま使えます。",
    },
    aura: {
      description:
        "GlowInput の WebGL 強化版です。rounded-box SDF と value-noise のシェーダー霧が縁に沿って漂い、入力に合わせて脈動します。canvas は <code>pointer-events: none</code> なので、入力は本物の DOM のままです。",
      note:
        "peer deps: <code>npm i three @react-three/fiber</code> — Next.js では <code>dynamic(…, &#123; ssr: false &#125;)</code> で読み込んでください。",
    },
    lock: {
      description:
        "扉面に本物の <code>&lt;input&gt;</code> を埋め込んだ 3D 南京錠。正しい keyword を入力するとシャックルが跳ね開き、錠前がパーティクルへ溶けて中身が現れます。間違えるとコーラル色に光って震えます。",
      note:
        "peer deps: <code>npm i three @react-three/fiber</code> — 演出用であり暗号ではありません。keyword はクライアントバンドルに含まれるため、本当の保護はサーバー側で行ってください。",
    },
    skyline: {
      tags: "準備中",
      title: "in orbit —",
      description:
        "astro-skyline の React 移植版。フォームの水平線に夜景のシルエットが浮かびます。",
    },
    principles: {
      domTitle: "Real DOM first",
      domBody:
        "装飾はすべて背面レイヤーです。input 自体には触れないので、日本語 IME、ペースト、スクリーンリーダーもそのまま動きます。",
      ssrTitle: "SSR safe",
      ssrBody:
        "canvas はマウント後にだけ生成されます。Next.js では <code>ssr: false</code> の dynamic import を使えます。",
      motionTitle: "Respects motion prefs",
      motionBody:
        "<code>prefers-reduced-motion</code> では動きをほぼ停止まで落とし、画面外では IntersectionObserver で描画を止めます。",
    },
  },
} as const;
const copy = localeCopy.en;

const glowSnippet = `import { GlowInput } from "@p4ni/ui";

<GlowInput
  placeholder="type here…"
  colors={["#7f77dd", "#1d9e75", "#d85a30", "#ed93b1"]}
  speed={3.2}
  intensity={0.45}
  reactive
/>`;

const auraSnippet = `import { AuraInput } from "@p4ni/ui/aura";

<AuraInput
  placeholder="type — the fog reacts…"
  colors={["#7f77dd", "#1d9e75", "#d85a30"]}
  speed={3.2}
  intensity={0.45}
  bleed={24}
  particles
/>`;

const lockSnippet = `import { LockInput } from "@p4ni/ui/three";

<LockInput
  keyword="${LOCK_KEYWORD}"          // string | RegExp | (value) => boolean
  placeholder="keyword"
  onUnlock={() => console.log("unlocked!")}
  onFail={(v) => console.log("wrong:", v)}
>
  <h2>UNLOCKED</h2>
</LockInput>`;
---

<Layout
  title={copy.meta.title}
  description={copy.meta.description}
>
  <header class="top">
    <div class="wrap top-row">
      <span class="brand">@p4ni/ui</span>
      <span class="ver">v0.2.0</span>
      <div class="top-tools">
        <div
          class="locale-switch"
          role="group"
          aria-label={copy.language.switcher}
          data-i18n-aria-label="language.switcher"
        >
          <span class="locale-label" data-i18n="language.label">{copy.language.label}</span>
          <div class="locale-options">
            <button class="locale-btn is-active" type="button" data-locale-option="en" aria-pressed="true">
              EN
            </button>
            <button class="locale-btn" type="button" data-locale-option="ja" aria-pressed="false">
              JP
            </button>
          </div>
        </div>
        <nav class="top-nav">
          <a href="#components" data-i18n="nav.components">{copy.nav.components}</a>
          <a href="https://github.com/kpab/p4ni-ui" data-i18n="nav.github">{copy.nav.github}</a>
          <a href="https://www.npmjs.com/package/@p4ni/ui" data-i18n="nav.npm">{copy.nav.npm}</a>
        </nav>
      </div>
    </div>
  </header>

  <main>
    <section class="hero wrap">
      <div class="hero-kanji" aria-hidden="true">光</div>
      <p class="eyebrow reveal" style="--d: 0s" data-i18n="hero.eyebrow">{copy.hero.eyebrow}</p>
      <h1 class="reveal" style="--d: 0.08s" data-i18n-html="hero.title" set:html={copy.hero.title}></h1>
      <p class="lede reveal" style="--d: 0.16s" data-i18n-html="hero.lede" set:html={copy.hero.lede}></p>
      <div class="install reveal" style="--d: 0.24s">
        <span><span class="dollar">$</span> {installCmd}</span>
        <button class="copy" data-copy={installCmd} data-copy-key="common.copy">
          {copy.common.copy}
        </button>
      </div>
      <div class="hero-demo reveal" style="--d: 0.34s">
        <HeroAura client:load />
      </div>
    </section>

    <section class="section wrap fade" id="components">
      <div class="section-grid">
        <aside class="meta">
          <div class="idx">01</div>
          <h2>GlowInput</h2>
          <div class="tags">css · zero deps</div>
          <p data-i18n="glow.description">{copy.glow.description}</p>
          <dl class="props">
            <div><dt>colors</dt><dd>string[]</dd></div>
            <div><dt>speed</dt><dd>3.2 s</dd></div>
            <div><dt>intensity</dt><dd>0.45</dd></div>
            <div><dt>reactive</dt><dd>true</dd></div>
            <div><dt>radius</dt><dd>14 px</dd></div>
            <div><dt>surface</dt><dd>#0d0d12</dd></div>
          </dl>
        </aside>
        <div>
          <GlowDemo client:visible />
          <div class="codeblock">
            <div class="codeblock-bar">
              <span>usage.tsx</span>
              <button class="copy" data-copy={glowSnippet} data-copy-key="common.copy">
                {copy.common.copy}
              </button>
            </div>
            <Code code={glowSnippet} lang="tsx" theme="poimandres" />
          </div>
        </div>
      </div>
    </section>

    <section class="section wrap fade">
      <div class="section-grid">
        <aside class="meta">
          <div class="idx">02</div>
          <h2>AuraInput</h2>
          <div class="tags">webgl · three + r3f</div>
          <p data-i18n-html="aura.description" set:html={copy.aura.description}></p>
          <dl class="props">
            <div><dt>particles</dt><dd>true</dd></div>
            <div><dt>bleed</dt><dd>24 px</dd></div>
            <div><dt>fps</dt><dd>uncapped</dd></div>
            <div><dt>+ GlowInput props</dt><dd>colors…</dd></div>
          </dl>
        </aside>
        <div>
          <AuraDemo client:visible />
          <div class="codeblock">
            <div class="codeblock-bar">
              <span>usage.tsx</span>
              <button class="copy" data-copy={auraSnippet} data-copy-key="common.copy">
                {copy.common.copy}
              </button>
            </div>
            <Code code={auraSnippet} lang="tsx" theme="poimandres" />
          </div>
          <p class="peer-note" data-i18n-html="aura.note" set:html={copy.aura.note}></p>
        </div>
      </div>
    </section>

    <section class="section wrap fade">
      <div class="section-grid">
        <aside class="meta">
          <div class="idx">03</div>
          <h2>LockInput</h2>
          <div class="tags">webgl · three + r3f</div>
          <p data-i18n-html="lock.description" set:html={copy.lock.description}></p>
          <dl class="props">
            <div><dt>keyword</dt><dd>string | RegExp | fn</dd></div>
            <div><dt>caseSensitive</dt><dd>false</dd></div>
            <div><dt>onUnlock / onFail</dt><dd>events</dd></div>
            <div><dt>ref.reset()</dt><dd>re-lock</dd></div>
          </dl>
        </aside>
        <div>
          <LockDemo client:visible />
          <div class="codeblock">
            <div class="codeblock-bar">
              <span>usage.tsx</span>
              <button class="copy" data-copy={lockSnippet} data-copy-key="common.copy">
                {copy.common.copy}
              </button>
            </div>
            <Code code={lockSnippet} lang="tsx" theme="poimandres" />
          </div>
          <p class="peer-note" data-i18n-html="lock.note" set:html={copy.lock.note}></p>
        </div>
      </div>
    </section>

    <section class="section wrap fade">
      <div class="section-grid">
        <aside class="meta">
          <div class="idx">04</div>
          <h2>Skyline</h2>
          <div class="tags" data-i18n="skyline.tags">{copy.skyline.tags}</div>
        </aside>
        <div class="ghost">
          <h2 data-i18n="skyline.title">{copy.skyline.title}</h2>
          <p data-i18n="skyline.description">{copy.skyline.description}</p>
        </div>
      </div>
    </section>

    <section class="principles wrap fade">
      <div>
        <h3 data-i18n="principles.domTitle">{copy.principles.domTitle}</h3>
        <p data-i18n="principles.domBody">{copy.principles.domBody}</p>
      </div>
      <div>
        <h3 data-i18n="principles.ssrTitle">{copy.principles.ssrTitle}</h3>
        <p data-i18n-html="principles.ssrBody" set:html={copy.principles.ssrBody}></p>
      </div>
      <div>
        <h3 data-i18n="principles.motionTitle">{copy.principles.motionTitle}</h3>
        <p data-i18n-html="principles.motionBody" set:html={copy.principles.motionBody}></p>
      </div>
    </section>
  </main>

  <footer class="wrap">
    <span>MIT © p4ni</span>
    <span>
      <a href="https://github.com/kpab/p4ni-ui">github</a> ·
      <a href="https://www.npmjs.com/package/@p4ni/ui">npm</a> ·
      <a href="https://p4ni.com">p4ni.com</a>
    </span>
  </footer>
</Layout>

<script define:vars={{ localeCopy }}>
  const STORAGE_KEY = "p4ni-ui-site-locale";
  const LOCALE_EVENT = "p4ni:localechange";

  const getValue = (locale, key) =>
    key.split(".").reduce((value, segment) => value?.[segment], localeCopy[locale]);

  const resolveLocale = (value) => (value === "ja" ? "ja" : "en");

  const applyLocale = (value) => {
    const locale = resolveLocale(value);
    const dictionary = localeCopy[locale];

    document.documentElement.lang = locale;
    document.documentElement.dataset.locale = locale;
    localStorage.setItem(STORAGE_KEY, locale);
    document.title = dictionary.meta.title;

    const meta = document.querySelector('meta[name="description"]');
    meta?.setAttribute("content", dictionary.meta.description);

    for (const el of document.querySelectorAll("[data-i18n]")) {
      const key = el.dataset.i18n;
      const next = key ? getValue(locale, key) : null;
      if (typeof next === "string") {
        el.textContent = next;
      }
    }

    for (const el of document.querySelectorAll("[data-i18n-html]")) {
      const key = el.dataset.i18nHtml;
      const next = key ? getValue(locale, key) : null;
      if (typeof next === "string") {
        el.innerHTML = next;
      }
    }

    for (const el of document.querySelectorAll("[data-i18n-aria-label]")) {
      const key = el.dataset.i18nAriaLabel;
      const next = key ? getValue(locale, key) : null;
      if (typeof next === "string") {
        el.setAttribute("aria-label", next);
      }
    }

    for (const btn of document.querySelectorAll("[data-locale-option]")) {
      const active = btn.dataset.localeOption === locale;
      btn.classList.toggle("is-active", active);
      btn.setAttribute("aria-pressed", active ? "true" : "false");
    }

    for (const btn of document.querySelectorAll("[data-copy-key]")) {
      if (!btn.classList.contains("done")) {
        btn.textContent = dictionary.common.copy;
      }
    }

    window.dispatchEvent(new Event(LOCALE_EVENT));
  };

  // copy buttons (scoped to [data-copy] — .copy is also used as a plain
  // button style, e.g. the LockInput demo's re-lock button)
  for (const btn of document.querySelectorAll("[data-copy]")) {
    btn.addEventListener("click", async () => {
      await navigator.clipboard.writeText(btn.dataset.copy ?? "");
      const prev = btn.textContent;
      const locale = resolveLocale(document.documentElement.dataset.locale);
      btn.textContent = localeCopy[locale].common.copied;
      btn.classList.add("done");
      setTimeout(() => {
        btn.textContent = prev;
        btn.classList.remove("done");
      }, 1400);
    });
  }

  // scroll reveals
  const io = new IntersectionObserver(
    (entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          e.target.classList.add("in");
          io.unobserve(e.target);
        }
      }
    },
    { threshold: 0.12 },
  );
  for (const el of document.querySelectorAll(".fade")) io.observe(el);

  for (const btn of document.querySelectorAll("[data-locale-option]")) {
    btn.addEventListener("click", () => applyLocale(btn.dataset.localeOption));
  }

  applyLocale(localStorage.getItem(STORAGE_KEY));
</script>
