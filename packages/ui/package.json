{
  "name": "@p4ni/ui",
  "version": "0.2.0",
  "description": "WebGL/CSS-flavored React UI effects by p4ni — glowing inputs and more.",
  "license": "MIT",
  "homepage": "https://ui.p4ni.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/kpab/p4ni-ui.git",
    "directory": "packages/ui"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "src", "CHANGELOG.md"],
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./aura": {
      "development": "./src/aura.ts",
      "types": "./dist/aura.d.ts",
      "default": "./dist/aura.js"
    },
    "./three": {
      "development": "./src/three/index.ts",
      "types": "./dist/three.d.ts",
      "default": "./dist/three.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@react-three/fiber": "^8.13.0 || ^9.0.0",
    "react": ">=18",
    "react-dom": ">=18",
    "three": ">=0.150.0"
  },
  "peerDependenciesMeta": {
    "@react-three/fiber": { "optional": true },
    "three": { "optional": true }
  },
  "devDependencies": {
    "@react-three/fiber": "^8.18.0",
    "@types/react": "^18.3.0",
    "@types/three": "^0.184.0",
    "react": "^18.3.0",
    "three": "^0.184.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  },
  "sideEffects": false
}
